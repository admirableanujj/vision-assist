# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API key — required for cloud LLM calls
OPENAI_API_KEY=sk-...

# PostgreSQL credentials
# NOTE: the password is NOT set here — it comes from a Docker secret
# (./secrets/postgres_password.txt, injected as POSTGRES_PASSWORD_FILE).
POSTGRES_USER=admin
POSTGRES_DB=vision_assist

# ---------------------------------------------------------------------------
# Secrets (NOT stored here — create these files under ./secrets/, git-ignored)
#   secrets/postgres_password.txt  -> Postgres password (POSTGRES_PASSWORD_FILE)
#   secrets/qdrant_api_key.txt     -> Qdrant API key   (QDRANT__SERVICE__API_KEY)
# ---------------------------------------------------------------------------
