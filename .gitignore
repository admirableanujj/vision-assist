# Ignore local environment keys
.env

# Ignore Python cache and compiler files
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Ignore Docker storage & local YOLO downloads
ollama_storage/
*.pt

# OS specific hidden files
.DS_Store
Thumbs.db

#Any local system backup files
*bkp*
*BKP*
*old*

# Ignore any documentation files
docs/
!docs/issues

# Ignore any audio files
*.mp3

# Ignore Docker secret files (contain the base64-encoded DB password)
secrets/
!secrets/.gitkeep
